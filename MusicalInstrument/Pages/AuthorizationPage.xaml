<Page x:Class="MusicalInstrument.Pages.AuthorizationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:MusicalInstrument.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Авторизация" Background="#F8F8FF"
      FontFamily="Times New Roman">

    <Grid>
        <!-- Логотип -->
        <Border Background="#483D8B" Height="100" VerticalAlignment="Top">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Image Source="/Images/music_logo.png" Height="60" Stretch="Uniform" Margin="10"/>
                <TextBlock Text="Скрипичный ключ" FontSize="28" FontWeight="Bold" VerticalAlignment="Center" Foreground="White"/>
            </StackPanel>
        </Border>

        <!-- Форма входа -->
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,50,0,0">
            <TextBlock Text="Логин" HorizontalAlignment="Center" FontSize="22" FontWeight="Bold" Foreground="#483D8B"/>
            <TextBox x:Name="loginBox" Width="280" Height="35" FontSize="18" Margin="0,0,0,15" FontFamily="Times New Roman" Background="White"/>

            <TextBlock Text="Пароль" HorizontalAlignment="Center" FontSize="22" FontWeight="Bold" Foreground="#483D8B"/>
            <PasswordBox x:Name="PasswordBox" Width="280" Height="35" FontSize="18" Margin="0,0,0,15" FontFamily="Times New Roman" Background="White"/>

            <TextBlock x:Name="errorBlock" Text="Неверный логин или пароль!" FontSize="14" Foreground="Red" HorizontalAlignment="Center" Margin="0,0,0,10" Visibility="Collapsed"/>

            <!-- CAPTCHA блок -->
            <Border x:Name="CaptchaBorder" CornerRadius="10" Background="#483D8B" Width="280" Height="70" Margin="0,0,0,10" Visibility="Collapsed">
                <Canvas x:Name="CaptchaCanvas" Width="280" Height="70" Background="#483D8B"/>
            </Border>

            <StackPanel x:Name="CaptchaInputPanel" Visibility="Collapsed">
                <TextBlock Text="Введите код с картинки" FontSize="14" Foreground="#483D8B" HorizontalAlignment="Center"/>
                <TextBox x:Name="CaptchaInputBox" Width="200" Height="30" FontSize="14" Margin="0,5,0,15" FontFamily="Times New Roman" HorizontalAlignment="Center"/>
            </StackPanel>

            <Button x:Name="enterButton" Content="Вход" Width="180" Height="40" FontSize="20" 
                    Background="#9400D3" Foreground="White" FontWeight="Bold" Cursor="Hand"
                    Click="enterButton_Click"/>

            <TextBlock HorizontalAlignment="Center" FontSize="16" Margin="10">
                <Hyperlink NavigateUri="GuestPage.xaml" RequestNavigate="Hyperlink_RequestNavigate" Foreground="#483D8B">Войти как Гость</Hyperlink>
            </TextBlock>
        </StackPanel>
    </Grid>
</Page>