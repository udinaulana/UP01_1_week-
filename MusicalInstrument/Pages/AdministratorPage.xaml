<Page x:Class="MusicalInstrument.Pages.AdministratorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:MusicalInstrument.Pages"
      xmlns:convert="clr-namespace:MusicalInstrument.Converters"
      mc:Ignorable="d" 
      d:DesignHeight="550" d:DesignWidth="1200"
      Title="Администратор" Background="#F8F8FF"
      FontFamily="Times New Roman">

    <Page.Resources>
        <convert:DiscountPrice x:Key="DiscountPrice"/>
        <convert:DiscountColor x:Key="DiscountColor"/>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#9400D3"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Width" Value="160"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="10,5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Width" Value="160"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Width" Value="160"/>
            <Setter Property="Background" Value="White"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Border Grid.Row="0" Background="#483D8B">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Image Source="/Images/music_logo.png" Height="45" Stretch="Uniform" Margin="10,0"/>
                    <TextBlock Text="Скрипичный ключ" FontSize="22" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="15,0">
                    <TextBlock Name="FIOBlok" Text="Фамилия Имя Отчество" FontSize="14" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" Margin="10,0"/>
                    <Button Name="exitButton" Content="Выход" Background="#9400D3" Foreground="White" FontWeight="Bold"
                            Width="90" Height="32" Click="exitButton_Click" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Панель фильтрации -->
        <Border Grid.Row="1" Background="#F0F0FF" BorderBrush="#483D8B" BorderThickness="0,0,0,1">
            <WrapPanel HorizontalAlignment="Center" Margin="10">
                <StackPanel Margin="10,5">
                    <TextBlock Text="Фильтр" FontSize="14" FontWeight="Bold" Foreground="#483D8B" HorizontalAlignment="Center"/>
                    <ComboBox Name="filterBox" Width="140" SelectionChanged="filterBox_SelectionChanged"/>
                </StackPanel>

                <StackPanel Margin="10,5">
                    <TextBlock Text="Сортировка" FontSize="14" FontWeight="Bold" Foreground="#483D8B" HorizontalAlignment="Center"/>
                    <ComboBox Name="sortBox" Width="140" SelectionChanged="sortBox_SelectionChanged">
                        <ComboBoxItem>По возрастанию</ComboBoxItem>
                        <ComboBoxItem>По убыванию</ComboBoxItem>
                    </ComboBox>
                </StackPanel>

                <StackPanel Margin="10,5">
                    <TextBlock Text="Поиск" FontSize="14" FontWeight="Bold" Foreground="#483D8B" HorizontalAlignment="Center"/>
                    <TextBox Name="searchBox" Width="180" TextChanged="searchBox_TextChanged"/>
                </StackPanel>

                <StackPanel Margin="10,5">
                    <TextBlock Text="Поставщик" FontSize="14" FontWeight="Bold" Foreground="#483D8B" HorizontalAlignment="Center"/>
                    <ComboBox Name="supplierFilterBox" Width="160" SelectionChanged="supplierFilterBox_SelectionChanged"/>
                </StackPanel>

                <TextBlock Name="RoleBlok" Text="Администратор" FontSize="14" Foreground="#9400D3" FontWeight="Bold" VerticalAlignment="Center" Margin="20,0"/>
            </WrapPanel>
        </Border>

        <!-- Список товаров (с двойным кликом для редактирования) -->
        <ListView Grid.Row="2" Name="ProductsList" Margin="10" ScrollViewer.HorizontalScrollBarVisibility="Disabled" 
          HorizontalContentAlignment="Center" SelectionChanged="ProductsList_SelectionChanged">
            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel/>
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>

            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border BorderThickness="2" BorderBrush="#483D8B" Width="550" 
                            Background="{Binding ., Converter={StaticResource DiscountColor}}"
                            CornerRadius="10" Margin="10" Padding="5"
                            MouseLeftButtonDown="Border_MouseLeftButtonDown">

                        <StackPanel Margin="5">
                            <!-- Верхняя часть -->
                            <StackPanel Orientation="Horizontal">
                                <Image Source="{Binding Photo}" Width="100" Height="120" Stretch="Uniform" Margin="0,0,10,0"/>

                                <StackPanel Width="380">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding PrkCategotyOrders.CategotyOrder}" 
                                                   FontWeight="Bold" FontSize="14" Foreground="#483D8B"/>
                                        <TextBlock Text=" | " FontWeight="Bold" FontSize="14" Foreground="#483D8B"/>
                                        <TextBlock Text="{Binding NameOrder}" FontWeight="Bold" FontSize="14" Foreground="#483D8B"/>
                                    </StackPanel>

                                    <TextBlock FontSize="12" Margin="0,5,0,0">
                                        <Run Text="Артикул: " FontWeight="Bold"/>
                                        <Run Text="{Binding Article}"/>
                                    </TextBlock>

                                    <TextBlock FontSize="12" TextWrapping="Wrap">
                                        <Run Text="Описание: " FontWeight="Bold"/>
                                        <Run Text="{Binding Description}"/>
                                    </TextBlock>

                                    <TextBlock FontSize="12">
                                        <Run Text="Производитель: " FontWeight="Bold"/>
                                        <Run Text="{Binding PrkManufacturers.Manufacturer}"/>
                                    </TextBlock>

                                    <TextBlock FontSize="12">
                                        <Run Text="Поставщик: " FontWeight="Bold"/>
                                        <Run Text="{Binding PrkSuppliers.Supplier}"/>
                                    </TextBlock>

                                    <TextBlock FontSize="12">
                                        <Run Text="Единица измерения: " FontWeight="Bold"/>
                                        <Run Text="{Binding PrkUunitOfMeasurements.UnitOfMeasurement}"/>
                                    </TextBlock>

                                    <TextBlock FontSize="12">
                                        <Run Text="Количество: " FontWeight="Bold"/>
                                        <TextBlock FontSize="12">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="{Binding QuantityInStock}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding QuantityInStock}" Value="0">
                                                            <Setter Property="Text" Value="НЕТ В НАЛИЧИИ"/>
                                                            <Setter Property="Foreground" Value="Red"/>
                                                            <Setter Property="FontWeight" Value="Bold"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <Run Text=" шт."/>
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>

                            <!-- Разделитель -->
                            <Border BorderBrush="#483D8B" BorderThickness="0,1,0,0" Margin="0,10,0,10"/>

                            <!-- Цена и скидка -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Цена: " FontWeight="Bold" FontSize="13"/>
                                        <TextBlock Text="{Binding Price}" Foreground="Red" TextDecorations="Strikethrough" FontSize="13"/>
                                        <TextBlock Text=" руб." Foreground="Red" TextDecorations="Strikethrough" FontSize="13"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                        <TextBlock Text="Цена со скидкой: " FontWeight="Bold" FontSize="13" Foreground="#483D8B"/>
                                        <TextBlock Margin="5,0,0,0" FontWeight="Bold" Foreground="Black" FontSize="16">
                                            <TextBlock.Text>
                                                <MultiBinding Converter="{StaticResource DiscountPrice}">
                                                    <Binding Path="Price"/>
                                                    <Binding Path="Discount"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="20,0,0,0">
                                    <TextBlock Text="Скидка" FontWeight="Bold" FontSize="12" Foreground="#483D8B" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding Discount, StringFormat={}{0}%}" 
                                               FontWeight="Bold" FontSize="18" 
                                               Foreground="Black" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Нижняя панель с 3 кнопками (Детали заказов, Добавить, Редактировать, Удалить) -->
        <Border Grid.Row="3" Background="#483D8B" Padding="15" Height="70">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Счетчик -->
                <TextBlock Name="CountInfoBlock" Grid.Column="0" 
                   Text="Показано: 0 из 0" 
                   FontSize="16" FontWeight="Bold" Foreground="White" 
                   VerticalAlignment="Center" Margin="20,0,0,0"/>

                <!-- Кнопка "Детали заказов" -->
                <Button Name="ordersButton" Grid.Column="1" 
                Content="Детали заказов" 
                Background="#20B2AA" Foreground="White" FontWeight="Bold"
                FontSize="14" Width="160" Height="45" 
                Click="ordersButton_Click" Cursor="Hand" Margin="5,0"/>

                <!-- Кнопка "Добавить товар" -->
                <Button Name="addButton" Grid.Column="2" 
                Content="Добавить товар" 
                Background="#9400D3" Foreground="White" FontWeight="Bold"
                FontSize="14" Width="140" Height="45" 
                Click="addButton_Click" Cursor="Hand" Margin="5,0"/>

                <!-- Кнопка "Удалить товар" -->
                <Button Name="deleteButton" Grid.Column="3" 
                Content="Удалить товар" 
                Background="#B8860B" Foreground="White" FontWeight="Bold"
                FontSize="14" Width="140" Height="45" 
                Click="deleteButton_Click" Cursor="Hand" Margin="5,0"/>
            </Grid>
        </Border>
    </Grid>
</Page>