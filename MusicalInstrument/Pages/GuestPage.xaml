<Page x:Class="MusicalInstrument.Pages.GuestPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:MusicalInstrument.Pages"
      xmlns:convert="clr-namespace:MusicalInstrument.Converters"
      mc:Ignorable="d" 
      d:DesignHeight="550" d:DesignWidth="1200"
       Title="Просмотр товаров" Background="#F8F8FF"
      FontFamily="Times New Roman">

    <Page.Resources>
        <convert:DiscountColor x:Key="DiscountColor"/>
        <convert:DiscountPrice x:Key="DiscountPrice"/>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Border Grid.Row="0" Background="#483D8B">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Image Source="/Images/music_logo.png" Height="45" Stretch="Uniform" Margin="10,0"/>
                    <TextBlock Text="Скрипичный ключ" FontSize="22" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="15,0">
                    <TextBlock Name="FIOBlok" Text="Гость" FontSize="16" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" Margin="10,0"/>
                    <Button Name="exitButton" Content="Выход" Width="90" Height="32" 
                            Background="#9400D3" Foreground="White" FontWeight="Bold" Cursor="Hand"
                            Click="exitButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Список товаров -->
        <ListView Grid.Row="1" Name="ProductsList" Margin="10" 
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled" HorizontalContentAlignment="Center">
            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel/>
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>

            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border BorderThickness="2" BorderBrush="#483D8B" Width="600" 
                            Background="{Binding ., Converter={StaticResource DiscountColor}}"
                            CornerRadius="10" Margin="10" Padding="5">

                        <StackPanel Margin="5" Orientation="Horizontal">
                            <Image Source="{Binding Photo}" Width="100" Height="120" Stretch="Uniform"/>

                            <StackPanel Margin="5" Width="390">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding PrkCategotyOrders.CategotyOrder}" 
                                               FontWeight="Bold" FontSize="14" Foreground="#483D8B"/>
                                    <TextBlock Text=" | " FontWeight="Bold" FontSize="14" Foreground="#483D8B"/>
                                    <TextBlock Text="{Binding NameOrder}" FontWeight="Bold" FontSize="14" Foreground="#483D8B"/>
                                </StackPanel>

                                <TextBlock FontSize="12" Margin="0,5,0,0">
                                    <Run Text="Артикул: " FontWeight="Bold"/>
                                    <Run Text="{Binding Article}"/>
                                </TextBlock>

                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Описание: " FontWeight="Bold" FontSize="12"/>
                                    <TextBlock Text="{Binding Description}" TextWrapping="Wrap" FontSize="12" Width="330"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Производитель: " FontWeight="Bold" FontSize="12"/>
                                    <TextBlock Text="{Binding PrkManufacturers.Manufacturer}" FontSize="12"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Поставщик: " FontWeight="Bold" FontSize="12"/>
                                    <TextBlock Text="{Binding PrkSuppliers.Supplier}" FontSize="12"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                    <TextBlock Text="Цена: " FontWeight="Bold" FontSize="13"/>
                                    <TextBlock Text="{Binding Price}" Foreground="Red" TextDecorations="Strikethrough" FontSize="13"/>
                                    <TextBlock Text=" руб." Foreground="Red" TextDecorations="Strikethrough" FontSize="13"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Цена со скидкой: " FontWeight="Bold" FontSize="13"/>
                                    <TextBlock Margin="5,0,0,0" FontWeight="Bold" Foreground="Black" FontSize="14">
                                        <TextBlock.Text>
                                            <MultiBinding Converter="{StaticResource DiscountPrice}">
                                                <Binding Path="Price"/>
                                                <Binding Path="Discount"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Единица измерения: " FontWeight="Bold" FontSize="12"/>
                                    <TextBlock Text="{Binding PrkUunitOfMeasurements.UnitOfMeasurement}" FontSize="12"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Количество: " FontWeight="Bold" FontSize="12"/>
                                    <TextBlock FontSize="12">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="{Binding QuantityInStock}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding QuantityInStock}" Value="0">
                                                        <Setter Property="Text" Value="НЕТ В НАЛИЧИИ"/>
                                                        <Setter Property="Foreground" Value="Red"/>
                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text=" шт." FontSize="12"/>
                                </StackPanel>
                            </StackPanel>

                            <TextBlock Text="{Binding Discount, StringFormat={}{0}%}" 
                                       FontWeight="Bold" FontSize="16" 
                                       Foreground="Black" VerticalAlignment="Center" 
                                       Width="50" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>