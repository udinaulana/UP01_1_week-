<Window x:Class="MusicalInstrument.Windows.OrderDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MusicalInstrument.Windows"
        xmlns:convert="clr-namespace:MusicalInstrument.Converters"
        mc:Ignorable="d"
        Title="Детали заказа" Height="600" Width="850"
        WindowStartupLocation="CenterOwner"
        Background="#F8F8FF"
        FontFamily="Times New Roman"
        ResizeMode="NoResize">

    <Window.Resources>
        <convert:DiscountPrice x:Key="DiscountPrice"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#483D8B" Padding="15">
            <TextBlock Name="OrderHeaderBlock" Text="ЗАКАЗ №" 
                       FontSize="22" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
        </Border>

        <!-- Карточка заказа -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="15">
            <StackPanel>

                <!-- Информация о заказе -->
                <Border Background="White" CornerRadius="10" BorderBrush="#483D8B" BorderThickness="2" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Информация о заказе" FontSize="16" FontWeight="Bold" Foreground="#483D8B" Margin="0,0,0,10"/>

                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Номер заказа:" FontWeight="Bold"/>
                            <TextBlock Grid.Column="1" Name="OrderCodeBlock"/>
                        </Grid>

                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Дата заказа:" FontWeight="Bold"/>
                            <TextBlock Grid.Column="1" Name="OrderDateBlock"/>
                        </Grid>

                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Статус:" FontWeight="Bold"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Name="OrderStatusBlock" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <Button Name="ChangeStatusButton" Content="Изменить статус" 
                                        Background="#9400D3" Foreground="White" FontWeight="Bold"
                                        Width="120" Height="28" Click="ChangeStatusButton_Click" Cursor="Hand"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Информация о клиенте -->
                <Border Background="White" CornerRadius="10" BorderBrush="#483D8B" BorderThickness="2" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Информация о клиенте" FontSize="16" FontWeight="Bold" Foreground="#483D8B" Margin="0,0,0,10"/>

                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="ФИО:" FontWeight="Bold"/>
                            <TextBlock Grid.Column="1" Name="ClientFIOBlock"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Состав заказа (карточки товаров) -->
                <Border Background="White" CornerRadius="10" BorderBrush="#483D8B" BorderThickness="2" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Состав заказа" FontSize="16" FontWeight="Bold" Foreground="#483D8B" Margin="0,0,0,10"/>

                        <ItemsControl Name="ProductsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="10" Margin="0,5">
                                        <StackPanel Orientation="Horizontal">
                                            <!-- Фото -->
                                            <Image Source="{Binding PrlProducts.Photo}" Width="80" Height="80" 
                                                   Stretch="Uniform" Margin="0,0,15,0"/>

                                            <!-- Информация -->
                                            <StackPanel Width="500">
                                                <TextBlock Text="{Binding PrlProducts.NameOrder}" FontSize="14" FontWeight="Bold" Foreground="#483D8B"/>
                                                <TextBlock FontSize="11">
                                                    <Run Text="Категория: " FontWeight="Bold"/><Run Text="{Binding PrlProducts.PrkCategotyOrders.CategotyOrder}"/>
                                                </TextBlock>
                                                <TextBlock FontSize="11">
                                                    <Run Text="Производитель: " FontWeight="Bold"/><Run Text="{Binding PrlProducts.PrkManufacturers.Manufacturer}"/>
                                                </TextBlock>
                                                <TextBlock FontSize="11">
                                                    <Run Text="Поставщик: " FontWeight="Bold"/><Run Text="{Binding PrlProducts.PrkSuppliers.Supplier}"/>
                                                </TextBlock>
                                                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                                    <TextBlock FontSize="12">
                                                        <Run Text="Количество: " FontWeight="Bold"/>
                                                        <Run Text="{Binding Quantity}"/>
                                                        <Run Text=" шт."/>
                                                    </TextBlock>
                                                    <TextBlock Margin="20,0,0,0" FontSize="12">
                                                        <Run Text="Цена: " FontWeight="Bold"/>
                                                        <Run Text="{Binding PrlProducts.Price}"/>
                                                        <Run Text=" руб."/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Итого -->
        <Border Grid.Row="2" Background="#483D8B" Padding="15">
            <StackPanel HorizontalAlignment="Right">
                <TextBlock Name="TotalOriginalBlock" FontSize="14" Foreground="White"/>
                <TextBlock Name="DiscountBlock" FontSize="14" Foreground="#FFD700"/>
                <TextBlock Name="TotalBlock" FontSize="20" FontWeight="Bold" Foreground="#FFD700"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>