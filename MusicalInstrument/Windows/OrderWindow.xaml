<Window x:Class="MusicalInstrument.Windows.OrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MusicalInstrument.Windows"
        xmlns:convert="clr-namespace:MusicalInstrument.Converters"
        mc:Ignorable="d"
        Title="Талон заказа" Height="450" Width="550"
        WindowStartupLocation="CenterOwner"
        Background="#F8F8FF"
        FontFamily="Times New Roman">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#483D8B" Padding="15">
            <TextBlock Name="FIOBlok" Text="Фамилия Имя Отчество" 
                       FontSize="18" FontWeight="Bold" Foreground="White" 
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- Информация о заказе -->
        <Border Grid.Row="1" Margin="20" Background="White" CornerRadius="10" Padding="15">
            <StackPanel>
                <TextBlock Name="TotalPriceBlock" FontSize="14" Margin="0,5" Foreground="#333"/>
                <TextBlock Name="DiscountBlock" FontSize="14" Margin="0,5" Foreground="#B8860B"/>
                <TextBlock Name="ResultPriceBlock" FontSize="18" FontWeight="Bold" Margin="0,10" Foreground="#9400D3"/>
            </StackPanel>
        </Border>

        <!-- Кнопка -->
        <Button Grid.Row="2" Name="FormCoupon" Content="Сформировать талон (PDF)" 
                Click="FormCoupon_Click" Width="250" Height="40" FontSize="14" 
                HorizontalAlignment="Center" Margin="20"
                Background="#9400D3" Foreground="White" FontWeight="Bold" Cursor="Hand"/>
    </Grid>
</Window>