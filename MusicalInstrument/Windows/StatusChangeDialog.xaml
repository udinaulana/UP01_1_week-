<Window x:Class="MusicalInstrument.Windows.StatusChangeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MusicalInstrument.Windows"
        mc:Ignorable="d"
        Title="Изменение статуса" Height="220" Width="400"
        WindowStartupLocation="CenterOwner"
        Background="#F8F8FF"
        FontFamily="Times New Roman">

    <Border Margin="15" Background="White" CornerRadius="10" Padding="15">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Выберите новый статус заказа:" FontSize="16" FontWeight="Bold" Foreground="#483D8B" Margin="0,0,0,15"/>

            <ComboBox Name="StatusCombo" Grid.Row="1" Margin="0,0,0,20" Height="35" FontSize="14"
                      Background="White" DisplayMemberPath="OrderStatus" SelectedValuePath="IdOrderStatus"/>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="Сохранить" Width="100" Height="35" Margin="5" 
                        Background="#9400D3" Foreground="White" FontWeight="Bold" Cursor="Hand" Click="Save_Click"/>
                <Button Content="Отмена" Width="100" Height="35" Margin="5" 
                        Background="#B8860B" Foreground="White" FontWeight="Bold" Cursor="Hand" Click="Cancel_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>